modules = ["nix", "bash"]
[agent]
expertMode = true

[nix]
packages = ["gh"]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run dinghy"

[[workflows.workflow]]
name = "Run dinghy"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "make run-dinghy"

[workflows.workflow.metadata]
outputType = "console"
